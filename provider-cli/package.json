{
  "name": "nexus-edge-engine",
  "version": "1.0.0",
  "description": "Decentralized mesh network micro-orchestrator running native edge runtimes.",
  "main": "gui.js",
  "scripts": {
    "start": "electron .",
    "build-all": "electron-builder --win --linux --mac"
  },
  "author": "Aritra Pradhan",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "^4.1.2",
    "dockerode": "^4.0.2",
    "express": "^4.19.2",
    "node-fetch": "^2.7.0",
    "simple-git": "^3.24.0",
    "tar-fs": "^3.0.6",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nexus.edge.engine",
    "productName": "NexusEdgeEngine",
    "directories": {
      "output": "../dashboard/public"
    },
    "win": {
      "target": "portable",
      "artifactName": "gui-win.exe"
    },
    "linux": {
      "target": "AppImage",
      "artifactName": "gui-linux",
      "category": "Utility"
    },
    "mac": {
      "target": "zip",
      "artifactName": "gui-macos.zip"
    }
  }
}